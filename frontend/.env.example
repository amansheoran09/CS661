# Frontend build-time config (Vite). Copy to .env.local for local overrides,
# or set these in the Vercel project's Environment Variables.
#
# Leave BOTH unset for local dev — the app falls back to the Vite proxy (/api)
# and ws://localhost:8080.

# Full URL of the backend API, including the /api suffix, no trailing slash:
VITE_API_BASE=https://cryptolens-api.onrender.com/api

# Live order-book relay over TLS (wss://), no trailing slash:
VITE_WS_URL=wss://cryptolens-ws.onrender.com
